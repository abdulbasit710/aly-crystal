# Copy this file to .env.local and fill in your Notion values.
# Connection name in Notion UI: SBF WORLD Platform. This name is not used in code.
# Keep these backend-only values out of frontend code.
NOTION_API_KEY=replace_with_my_notion_integration_secret
NOTION_GODS_BLUEPRINT_PAGE_ID=replace_with_my_notion_page_id

# Optional public website CMS feed. Use the Notion data source ID, not the token.
# Suggested columns: Title, Section, Description, Status, Order, Button Label, Button URL, Image, Tags.
NOTION_SITE_CONTENT_DATA_SOURCE_ID=replace_with_my_notion_data_source_id

# Portal authentication data.
# Use the 02 — People, Members & Relationships — CORE data_source ID, or keep auto if the database is shared with the connection.
NOTION_PEOPLE_DATA_SOURCE_ID=auto

# Optional fallback login users database/data source.
NOTION_PORTAL_USERS_DATA_SOURCE_ID=auto

# Login codes are generated on screen after Notion verifies the user. No SMTP email setup is required.
# Optional but recommended on Vercel: use any long random secret so screen codes verify across serverless functions.
PORTAL_CODE_SECRET=replace_with_long_random_secret

# Optional parent page where partner intake/support/update submissions are created as child pages.
# Defaults to NOTION_GODS_BLUEPRINT_PAGE_ID if left as auto.
NOTION_PARTNER_INTAKE_PARENT_PAGE_ID=auto
NOTION_SUBMISSIONS_PARENT_PAGE_ID=auto

# Preferred CRM submission pipeline. Create/share a Notion data source named "Partner Submissions — CORE" or keep auto.
# New portal submissions are saved as database rows here, with status tracking, when this source is available.
NOTION_PARTNER_SUBMISSIONS_DATA_SOURCE_ID=auto

# SBF WORLD live AI assistant.
# Add an OpenAI API key to enable true AI responses. Without it, the widget uses a safe fallback mode.
OPENAI_API_KEY=replace_with_my_openai_api_key
OPENAI_ASSISTANT_MODEL=gpt-4.1-mini

# Optional: create a public Notion page named "SBF WORLD AI Assistant Knowledge Base" and share it with SBF WORLD Platform.
# Use this for visitor-safe answers. Do NOT point this to private CORE databases.
NOTION_ASSISTANT_PUBLIC_SOURCE_PAGE_ID=replace_with_public_assistant_page_id
